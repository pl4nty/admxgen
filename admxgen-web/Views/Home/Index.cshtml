@{
    ViewData["Title"] = "ADMX Generator";
}

<h2>ADMX Generator</h2>

<form asp-action="Index" method="post">
    <div class="form-group">
        <label for="displayName">Display Name</label>
        <input type="text" class="form-control" id="displayName" name="displayName" required />
    </div>
    <div class="form-group">
        <label for="description">Description</label>
        <input type="text" class="form-control" id="description" name="description" required />
    </div>
    <div class="form-group">
        <label for="revision">Revision</label>
        <input type="text" class="form-control" id="revision" name="revision" required />
    </div>
    <div class="form-group">
        <label for="minRequiredRevision">Min Required Revision</label>
        <input type="text" class="form-control" id="minRequiredRevision" name="minRequiredRevision" required />
    </div>
    <div class="form-group">
        <label for="schemaVersion">Schema Version</label>
        <input type="text" class="form-control" id="schemaVersion" name="schemaVersion" required />
    </div>
    <div class="form-group">
        <label for="targetNamespacePrefix">Target Namespace Prefix</label>
        <input type="text" class="form-control" id="targetNamespacePrefix" name="targetNamespacePrefix" required />
    </div>
    <div class="form-group">
        <label for="targetNamespace">Target Namespace</label>
        <input type="text" class="form-control" id="targetNamespace" name="targetNamespace" required />
    </div>
    <div class="form-group">
        <label for="fallbackCulture">Fallback Culture</label>
        <input type="text" class="form-control" id="fallbackCulture" name="fallbackCulture" required />
    </div>
    <div class="form-group">
        <label for="supersededPolicyFiles">Superseded Policy Files (comma-separated)</label>
        <input type="text" class="form-control" id="supersededPolicyFiles" name="supersededPolicyFiles" required />
    </div>
    <div class="form-group">
        <label for="csvData">CSV Data</label>
        <textarea class="form-control" id="csvData" name="csvData" rows="10" required></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Generate</button>
</form>
